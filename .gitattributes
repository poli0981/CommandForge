# Normalize line endings. Source checks out CRLF on every platform so it matches
# .editorconfig (end_of_line = crlf) and keeps `dotnet format` / CI deterministic.
* text=auto eol=crlf

# Tooling files that must stay LF regardless of platform (CI scripts / workflows).
*.sh   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.snk   binary
*.nupkg binary
