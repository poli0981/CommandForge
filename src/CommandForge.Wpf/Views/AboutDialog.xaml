<Window x:Class="CommandForge.Wpf.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:CommandForge.Wpf.Resources"
        Title="{res:Loc Menu_About}"
        Width="460" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="{DynamicResource MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontSize="{DynamicResource AppFontSize}"
        Background="{DynamicResource MaterialDesignPaper}">
    <StackPanel Margin="24">
        <TextBlock Text="{res:Loc AppTitle}" FontSize="22" FontWeight="Bold" />
        <TextBlock x:Name="VersionText" Opacity="0.8" Margin="0,4,0,0" />
        <TextBlock Text="{res:Loc Settings_NoDataCollected}" TextWrapping="Wrap" Opacity="0.8" Margin="0,12,0,0" />

        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
            <Button Content="{res:Loc Settings_License}" Click="OnLicenseClick"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0" />
            <Button Content="{res:Loc Settings_GitHub}" Click="OnGitHubClick"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0" />
            <Button Content="{res:Loc Menu_Wiki}" Click="OnWikiClick"
                    Style="{StaticResource MaterialDesignOutlinedButton}" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="{res:Loc Menu_Terms}" Click="OnTermsClick"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0" />
            <Button Content="{res:Loc ReportBug_Close}" Click="OnCloseClick"
                    Style="{StaticResource MaterialDesignRaisedButton}" />
        </StackPanel>
    </StackPanel>
</Window>
