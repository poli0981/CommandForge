<Window x:Class="CommandForge.Wpf.Views.CommandPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:res="clr-namespace:CommandForge.Wpf.Resources"
        xmlns:conv="clr-namespace:CommandForge.Wpf.Converters"
        xmlns:beh="clr-namespace:CommandForge.Wpf.Behaviors"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        Width="640"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        PreviewKeyDown="OnPreviewKeyDown">
    <Window.Resources>
        <conv:StringToPackIconKindConverter x:Key="IconConverter" />
        <conv:DangerLevelToBrushConverter x:Key="DangerBrush" />
    </Window.Resources>

    <materialDesign:Card Margin="16" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp8"
                         Background="{DynamicResource MaterialDesignPaper}">
        <DockPanel>
            <Grid DockPanel.Dock="Top" Margin="14,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Grid.Column="0" Kind="Magnify" Width="22" Height="22"
                                         VerticalAlignment="Center" Opacity="0.7" Margin="0,0,8,0" />
                <TextBox x:Name="SearchBox" Grid.Column="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="16" BorderThickness="0"
                         materialDesign:HintAssist.Hint="{res:Loc Palette_Placeholder}"
                         materialDesign:TextFieldAssist.DecorationVisibility="Collapsed" />
            </Grid>

            <Separator DockPanel.Dock="Top" Margin="0" Opacity="0.4" />

            <ListBox x:Name="ResultsList" MaxHeight="360"
                     ItemsSource="{Binding Results}"
                     SelectedItem="{Binding SelectedResult}"
                     MouseDoubleClick="OnResultDoubleClick"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0"
                                                     Kind="{Binding Icon, Converter={StaticResource IconConverter}}"
                                                     Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                       beh:TextHighlight.Text="{Binding Title}"
                                       beh:TextHighlight.Matches="{Binding TitleMatches}" />
                            <Ellipse Grid.Column="2" Width="9" Height="9" VerticalAlignment="Center"
                                     Fill="{Binding DangerLevel, Converter={StaticResource DangerBrush}}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </materialDesign:Card>
</Window>
