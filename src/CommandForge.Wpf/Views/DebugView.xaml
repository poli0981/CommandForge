<UserControl x:Class="CommandForge.Wpf.Views.DebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:CommandForge.Wpf.Resources">
    <Grid Margin="12">
        <TabControl>
            <TabItem Header="{res:Loc Debug_TabVerbose}">
                <DockPanel Margin="8">
                    <Button DockPanel.Dock="Top" HorizontalAlignment="Left" Margin="0,0,0,8"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Content="{res:Loc Debug_Refresh}" Command="{Binding RefreshCommand}"
                            AutomationProperties.Name="{res:Loc Debug_Refresh}" />
                    <Border Background="{DynamicResource MaterialDesignToolBarBackground}" CornerRadius="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="8">
                            <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True" BorderThickness="0"
                                     Background="Transparent" TextWrapping="NoWrap"
                                     FontFamily="Cascadia Mono, Consolas, Courier New" FontSize="12" />
                        </ScrollViewer>
                    </Border>
                </DockPanel>
            </TabItem>

            <TabItem Header="{res:Loc Debug_TabCatalog}">
                <StackPanel Margin="8">
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="{res:Loc Debug_CategoryCount}" Opacity="0.7" />
                        <TextBlock Text="{Binding CategoryCount}" Margin="8,0,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="{res:Loc Debug_CommandCount}" Opacity="0.7" />
                        <TextBlock Text="{Binding CommandCount}" Margin="8,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="{res:Loc Debug_ValidationErrors}" FontWeight="Medium" Margin="0,12,0,4" />
                    <TextBlock Text="{res:Loc Debug_NoValidationErrors}" Opacity="0.7">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasValidationErrors}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding ValidationErrors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#E05B5B" Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </TabItem>

            <TabItem Header="{res:Loc Debug_TabSystemInfo}">
                <DockPanel Margin="8">
                    <Button DockPanel.Dock="Top" HorizontalAlignment="Left" Margin="0,0,0,8"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Content="{res:Loc Debug_CopySystemInfo}" Command="{Binding CopySystemInfoCommand}"
                            AutomationProperties.Name="{res:Loc Debug_CopySystemInfo}" />
                    <Border Background="{DynamicResource MaterialDesignToolBarBackground}" CornerRadius="4">
                        <TextBox Text="{Binding SystemInfo, Mode=OneWay}" IsReadOnly="True" BorderThickness="0"
                                 Background="Transparent" Margin="8" TextWrapping="Wrap"
                                 FontFamily="Cascadia Mono, Consolas, Courier New" FontSize="12" />
                    </Border>
                </DockPanel>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
