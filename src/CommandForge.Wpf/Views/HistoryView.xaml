<UserControl x:Class="CommandForge.Wpf.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:res="clr-namespace:CommandForge.Wpf.Resources"
             xmlns:conv="clr-namespace:CommandForge.Wpf.Converters">
    <UserControl.Resources>
        <conv:StringToPackIconKindConverter x:Key="IconConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- One past run: icon, title + metadata line (time · status · duration), and a Run-again button. -->
        <DataTemplate x:Key="HistoryItem">
            <Border Padding="10,8" Margin="0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Grid.Column="0"
                                             Kind="{Binding Icon, Converter={StaticResource IconConverter}}"
                                             Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal" Opacity="0.6">
                            <TextBlock Text="{Binding TimeText}" FontSize="12" />
                            <TextBlock Text=" · " FontSize="12" />
                            <TextBlock Text="{Binding StatusText}" FontSize="12" />
                            <TextBlock Text=" · " FontSize="12" />
                            <TextBlock Text="{Binding DurationText}" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Style="{StaticResource MaterialDesignFlatButton}"
                            VerticalAlignment="Center" Content="{res:Loc History_RunAgain}"
                            IsEnabled="{Binding CanRun}"
                            Command="{Binding DataContext.RunAgainCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,24">
        <StackPanel MaxWidth="1000" HorizontalAlignment="Left">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{res:Loc History_Title}" FontSize="24" FontWeight="Bold"
                           VerticalAlignment="Center" AutomationProperties.HeadingLevel="Level1" />
                <Button Grid.Column="1" Style="{StaticResource MaterialDesignFlatButton}"
                        Content="{res:Loc History_Clear}" Command="{Binding ClearCommand}"
                        Visibility="{Binding HasEntries, Converter={StaticResource BoolToVis}}" />
            </Grid>

            <materialDesign:Card Padding="6" Margin="0,12,0,8">
                <Grid>
                    <ItemsControl ItemsSource="{Binding Entries}" ItemTemplate="{StaticResource HistoryItem}"
                                  Visibility="{Binding HasEntries, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{res:Loc History_Empty}" Opacity="0.6" Margin="10" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasEntries}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
