<UserControl x:Class="CommandForge.Wpf.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:res="clr-namespace:CommandForge.Wpf.Resources"
             xmlns:conv="clr-namespace:CommandForge.Wpf.Converters">
    <UserControl.Resources>
        <conv:StringToPackIconKindConverter x:Key="IconConverter" />
        <conv:DangerLevelToBrushConverter x:Key="DangerBrush" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- A clickable command row shared by the Recent and Favorites lists. -->
        <DataTemplate x:Key="HomeCommandItem">
            <!-- No explicit AutomationProperties.Name: the button auto-names from its content
                 (title + description), giving screen-reader users the same context as sighted users. -->
            <Button Style="{StaticResource MaterialDesignFlatButton}" HorizontalContentAlignment="Stretch"
                    Padding="10,8" Margin="0,1"
                    Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Grid.Column="0"
                                             Kind="{Binding Icon, Converter={StaticResource IconConverter}}"
                                             Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Description}" Opacity="0.6" FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Ellipse Grid.Column="2" Width="9" Height="9" VerticalAlignment="Center"
                             Fill="{Binding DangerLevel, Converter={StaticResource DangerBrush}}" />
                </Grid>
            </Button>
        </DataTemplate>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Margin" Value="0,16,0,8" />
            <Setter Property="AutomationProperties.HeadingLevel" Value="Level2" />
        </Style>

        <Style x:Key="StatusCardStyle" TargetType="materialDesign:Card">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Width" Value="220" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,18">
        <StackPanel MaxWidth="1000" HorizontalAlignment="Left">
            <TextBlock Text="{res:Loc SidebarHome}" FontSize="24" FontWeight="Bold"
                       AutomationProperties.HeadingLevel="Level1" />

            <!-- System status widget (read-only) -->
            <TextBlock Text="{res:Loc Home_SystemStatus}" Style="{StaticResource SectionHeaderStyle}" />
            <WrapPanel>
                <materialDesign:Card Style="{StaticResource StatusCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Microsoft" Width="18" Height="18" Opacity="0.7" VerticalAlignment="Center" />
                            <TextBlock Text="{res:Loc Home_StatusOs}" Opacity="0.7" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="{Binding OsValue}" FontWeight="Medium" Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Style="{StaticResource StatusCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Memory" Width="18" Height="18" Opacity="0.7" VerticalAlignment="Center" />
                            <TextBlock Text="{res:Loc Home_StatusMemory}" Opacity="0.7" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="{Binding MemoryValue}" FontWeight="Medium" Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Style="{StaticResource StatusCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Harddisk" Width="18" Height="18" Opacity="0.7" VerticalAlignment="Center" />
                            <TextBlock Text="{res:Loc Home_StatusDisk}" Opacity="0.7" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="{Binding DiskValue}" FontWeight="Medium" Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Style="{StaticResource StatusCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ClockOutline" Width="18" Height="18" Opacity="0.7" VerticalAlignment="Center" />
                            <TextBlock Text="{res:Loc Home_StatusUptime}" Opacity="0.7" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="{Binding UptimeValue}" FontWeight="Medium" Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </materialDesign:Card>
            </WrapPanel>

            <!-- Recently-run commands -->
            <TextBlock Text="{res:Loc Home_Recent}" Style="{StaticResource SectionHeaderStyle}" />
            <materialDesign:Card Padding="6">
                <Grid>
                    <ItemsControl ItemsSource="{Binding Recent}" ItemTemplate="{StaticResource HomeCommandItem}"
                                  Visibility="{Binding HasRecent, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{res:Loc Home_NoRecent}" Opacity="0.6" Margin="10" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasRecent}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </materialDesign:Card>

            <!-- Pinned favorites -->
            <TextBlock Text="{res:Loc SidebarFavorites}" Style="{StaticResource SectionHeaderStyle}" />
            <materialDesign:Card Padding="6" Margin="0,0,0,8">
                <Grid>
                    <ItemsControl ItemsSource="{Binding Favorites}" ItemTemplate="{StaticResource HomeCommandItem}"
                                  Visibility="{Binding HasFavorites, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{res:Loc Home_NoFavorites}" Opacity="0.6" Margin="10" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasFavorites}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
