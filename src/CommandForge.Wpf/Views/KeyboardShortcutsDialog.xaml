<Window x:Class="CommandForge.Wpf.Views.KeyboardShortcutsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:CommandForge.Wpf.Resources"
        Title="{res:Loc Menu_KeyboardShortcuts}"
        Width="440" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="{DynamicResource MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontSize="{DynamicResource AppFontSize}"
        Background="{DynamicResource MaterialDesignPaper}">
    <StackPanel Margin="24">
        <TextBlock Text="{res:Loc Menu_KeyboardShortcuts}" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />

        <ItemsControl ItemsSource="{Binding}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource MaterialDesignToolBarBackground}"
                                CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Key}" FontFamily="Cascadia Mono, Consolas, Courier New" FontSize="12" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding Action}" VerticalAlignment="Center"
                                   Margin="12,0,0,0" TextWrapping="Wrap" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Content="{res:Loc ReportBug_Close}" Click="OnCloseClick"
                HorizontalAlignment="Right" Margin="0,16,0,0"
                Style="{StaticResource MaterialDesignRaisedButton}" />
    </StackPanel>
</Window>
