<Window x:Class="CommandForge.Wpf.Views.LegalViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:CommandForge.Wpf.Resources"
        xmlns:views="clr-namespace:CommandForge.Wpf.Views"
        Title="{res:Loc LegalViewer_Title}"
        Width="700" Height="520"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="{DynamicResource MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontSize="{DynamicResource AppFontSize}"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <views:LegalDocumentsView Grid.Row="0" />

        <Button Grid.Row="1" Content="{res:Loc ReportBug_Close}" Click="OnCloseClick"
                HorizontalAlignment="Right" Margin="0,16,0,0"
                Style="{StaticResource MaterialDesignRaisedButton}" />
    </Grid>
</Window>
