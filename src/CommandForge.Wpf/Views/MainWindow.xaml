<Window x:Class="CommandForge.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:res="clr-namespace:CommandForge.Wpf.Resources"
        Title="{x:Static res:Strings.AppTitle}"
        Width="1100" Height="720" MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        FontFamily="{DynamicResource MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontSize="13"
        Background="{DynamicResource MaterialDesignPaper}">
    <Window.Resources>
        <Style x:Key="SidebarLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="16,0,0,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Height" Value="44" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{x:Static res:Strings.MenuFile}">
                <MenuItem Header="{x:Static res:Strings.MenuExit}" Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="{x:Static res:Strings.MenuView}">
                <MenuItem Header="{x:Static res:Strings.MenuToggleSidebar}"
                          Command="{Binding ToggleSidebarCommand}" />
            </MenuItem>
            <MenuItem Header="{x:Static res:Strings.MenuTools}" />
            <MenuItem Header="{x:Static res:Strings.MenuAbout}" />
            <MenuItem Header="{x:Static res:Strings.MenuHelp}" />
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Collapsible sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource MaterialDesignToolBarBackground}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Width" Value="220" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                <Setter Property="Width" Value="56" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DockPanel>
                    <Button DockPanel.Dock="Top"
                            Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding ToggleSidebarCommand}"
                            ToolTip="{x:Static res:Strings.MenuToggleSidebar}">
                        <materialDesign:PackIcon Kind="Menu" Width="22" Height="22" />
                    </Button>

                    <Button DockPanel.Dock="Bottom" Style="{StaticResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cog" Width="22" Height="22" />
                            <TextBlock Text="{x:Static res:Strings.SidebarSettings}" Style="{StaticResource SidebarLabelStyle}" />
                        </StackPanel>
                    </Button>

                    <StackPanel DockPanel.Dock="Top">
                        <Button Style="{StaticResource SidebarButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Home" Width="22" Height="22" />
                                <TextBlock Text="{x:Static res:Strings.SidebarHome}" Style="{StaticResource SidebarLabelStyle}" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Star" Width="22" Height="22" />
                                <TextBlock Text="{x:Static res:Strings.SidebarFavorites}" Style="{StaticResource SidebarLabelStyle}" />
                            </StackPanel>
                        </Button>
                        <Separator Margin="8,8" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content: three placeholder panes (list / details / console) -->
            <Grid Grid.Column="1" Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="180" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="2*" MinWidth="240" />
                </Grid.ColumnDefinitions>

                <materialDesign:Card Grid.Column="0" Margin="4" Padding="12">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{x:Static res:Strings.PaneCommands}" FontWeight="Bold" Margin="0,0,0,8" />
                        <TextBlock Text="{x:Static res:Strings.ComingSoon}" Opacity="0.6" />
                    </DockPanel>
                </materialDesign:Card>

                <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" />

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <materialDesign:Card Grid.Row="0" Margin="4" Padding="12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="{x:Static res:Strings.PaneDetails}" FontWeight="Bold" Margin="0,0,0,8" />
                            <TextBlock Text="{x:Static res:Strings.ComingSoon}" Opacity="0.6" />
                        </DockPanel>
                    </materialDesign:Card>

                    <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center" />

                    <materialDesign:Card Grid.Row="2" Margin="4" Padding="12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="{x:Static res:Strings.PaneConsole}" FontWeight="Bold" Margin="0,0,0,8" />
                            <TextBlock Text="{x:Static res:Strings.ComingSoon}" Opacity="0.6"
                                       FontFamily="Cascadia Mono, Consolas, Courier New" />
                        </DockPanel>
                    </materialDesign:Card>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
