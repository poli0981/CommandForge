<Window x:Class="CommandForge.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:res="clr-namespace:CommandForge.Wpf.Resources"
        xmlns:conv="clr-namespace:CommandForge.Wpf.Converters"
        xmlns:views="clr-namespace:CommandForge.Wpf.Views"
        Title="{res:Loc AppTitle}"
        Width="1100" Height="720" MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        FontFamily="{DynamicResource MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontSize="{DynamicResource AppFontSize}"
        Background="{DynamicResource MaterialDesignPaper}"
        PreviewKeyDown="OnWindowPreviewKeyDown"
        Closing="OnWindowClosing">
    <Window.Resources>
        <conv:StringToPackIconKindConverter x:Key="IconConverter" />

        <DataTemplate x:Key="HomeTemplate">
            <views:HomeView DataContext="{Binding Home}" />
        </DataTemplate>
        <DataTemplate x:Key="CatalogTemplate">
            <views:CatalogView />
        </DataTemplate>
        <DataTemplate x:Key="SettingsTemplate">
            <views:SettingsView DataContext="{Binding Settings}" />
        </DataTemplate>
        <DataTemplate x:Key="LogViewerTemplate">
            <views:LogViewerView DataContext="{Binding LogViewer}" />
        </DataTemplate>
        <DataTemplate x:Key="DebugTemplate">
            <views:DebugView DataContext="{Binding Debug}" />
        </DataTemplate>

        <Style x:Key="SidebarLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="14,0,0,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Height" Value="44" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{res:Loc MenuFile}">
                <MenuItem Header="{res:Loc MenuExit}" Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="{res:Loc MenuView}">
                <MenuItem Header="{res:Loc SidebarHome}" Command="{Binding ShowHomeCommand}" InputGestureText="Ctrl+H" />
                <MenuItem Header="{res:Loc SidebarFavorites}" Command="{Binding ShowFavoritesCommand}" />
                <Separator />
                <MenuItem Header="{res:Loc MenuToggleSidebar}" Command="{Binding ToggleSidebarCommand}" InputGestureText="Ctrl+B" />
                <MenuItem Header="{res:Loc Menu_OpenSettings}" Command="{Binding ShowSettingsCommand}" InputGestureText="Ctrl+," />
            </MenuItem>
            <MenuItem Header="{res:Loc MenuTools}">
                <MenuItem Header="{res:Loc Palette_Placeholder}" Click="OnOpenPaletteClick" InputGestureText="Ctrl+K" />
                <MenuItem Header="{res:Loc Menu_LogViewer}" Command="{Binding ShowLogViewerCommand}" InputGestureText="Ctrl+L" />
                <MenuItem Header="{res:Loc Menu_ExportLogs}" Command="{Binding LogViewer.ExportZipCommand}" />
                <MenuItem Header="{res:Loc Menu_DebugPanel}" Command="{Binding ShowDebugCommand}" />
                <Separator />
                <MenuItem Header="{res:Loc Menu_CheckForUpdates}" Command="{Binding CheckForUpdatesCommand}" />
            </MenuItem>
            <MenuItem Header="{res:Loc MenuAbout}" />
            <MenuItem Header="{res:Loc MenuHelp}">
                <MenuItem Header="{res:Loc Menu_ReportBug}" Command="{Binding ReportBugCommand}" />
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar: categories -->
            <Border Grid.Column="0" Background="{DynamicResource MaterialDesignToolBarBackground}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Width" Value="230" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                <Setter Property="Width" Value="56" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DockPanel>
                    <Button DockPanel.Dock="Top" Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding ToggleSidebarCommand}"
                            AutomationProperties.Name="{res:Loc MenuToggleSidebar}"
                            ToolTip="{res:Loc MenuToggleSidebar}">
                        <materialDesign:PackIcon Kind="Menu" Width="22" Height="22" />
                    </Button>

                    <Button DockPanel.Dock="Top" Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding ShowHomeCommand}"
                            AutomationProperties.Name="{res:Loc SidebarHome}"
                            ToolTip="{res:Loc SidebarHome}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Home" Width="22" Height="22" />
                            <TextBlock Text="{res:Loc SidebarHome}" Style="{StaticResource SidebarLabelStyle}" />
                        </StackPanel>
                    </Button>

                    <Button DockPanel.Dock="Top" Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding ShowFavoritesCommand}"
                            AutomationProperties.Name="{res:Loc SidebarFavorites}"
                            ToolTip="{res:Loc SidebarFavorites}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Star" Width="22" Height="22" />
                            <TextBlock Text="{res:Loc SidebarFavorites}" Style="{StaticResource SidebarLabelStyle}" />
                        </StackPanel>
                    </Button>

                    <Button DockPanel.Dock="Bottom" Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding ShowSettingsCommand}"
                            AutomationProperties.Name="{res:Loc SidebarSettings}"
                            ToolTip="{res:Loc SidebarSettings}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cog" Width="22" Height="22" />
                            <TextBlock Text="{res:Loc SidebarSettings}" Style="{StaticResource SidebarLabelStyle}" />
                        </StackPanel>
                    </Button>

                    <ListBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                             Background="Transparent" BorderThickness="0" Padding="4,4"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="Padding" Value="12,8" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Grid.Column="0"
                                                             Kind="{Binding Icon, Converter={StaticResource IconConverter}}"
                                                             Width="22" Height="22" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                               Style="{StaticResource SidebarLabelStyle}" />
                                    <TextBlock Grid.Column="2" Text="{Binding Count}" Opacity="0.6"
                                               Style="{StaticResource SidebarLabelStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Content: swaps between Catalog and Settings (Home added in 5c) -->
            <ContentControl Grid.Column="1" Content="{Binding}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="ContentTemplate" Value="{StaticResource CatalogTemplate}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentSection}" Value="Home">
                                <Setter Property="ContentTemplate" Value="{StaticResource HomeTemplate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentSection}" Value="Settings">
                                <Setter Property="ContentTemplate" Value="{StaticResource SettingsTemplate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentSection}" Value="LogViewer">
                                <Setter Property="ContentTemplate" Value="{StaticResource LogViewerTemplate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentSection}" Value="Debug">
                                <Setter Property="ContentTemplate" Value="{StaticResource DebugTemplate}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>
    </DockPanel>
</Window>
